# Dockerfile for GoReleaser dockers_v2 — uses pre-built binaries, NO go build.
# GoReleaser places per-platform binaries under $TARGETPLATFORM/ in the context.
# This avoids redundant compilation: GoReleaser builds once, Docker just packages.
FROM gcr.io/distroless/static-debian12:nonroot

WORKDIR /
ARG TARGETPLATFORM
COPY $TARGETPLATFORM/manager /manager
COPY $TARGETPLATFORM/k8ops /usr/local/bin/k8ops

ENTRYPOINT ["/manager"]
