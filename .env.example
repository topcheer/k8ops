# =============================================================================
# k8ops Environment Variables Reference
# =============================================================================
# Copy to .env and fill in your values. .env is gitignored.
#
# For Kubernetes deployment, these map to:
#   - ConfigMap (k8ops-config): non-sensitive settings
#   - Secret (k8ops-auth, k8ops-credentials, k8ops-notifications): sensitive values

# ============================================================================
# AI Provider (required)
# ============================================================================
PROVIDER_TYPE=openai                    # openai, anthropic, gemini
PROVIDER_MODEL=gpt-4o                   # model name (leave empty for provider default)
PROVIDER_ENDPOINT=https://api.openai.com/v1   # custom API endpoint

# API Key — store in Kubernetes Secret, NOT here for production
# kubectl create secret generic k8ops-credentials \
#   --from-literal=api-key="sk-xxxx" -n k8ops-system
AIOPS_API_KEY=                          # k8ops-credentials/api-key

# ============================================================================
# Authentication (required for production)
# ============================================================================
# JWT signing secret — generate with: openssl rand -base64 32
# kubectl create secret generic k8ops-auth \
#   --from-literal=jwt-secret="$(openssl rand -base64 32)" -n k8ops-system
AUTH_JWT_SECRET=                        # k8ops-auth/jwt-secret

# Database
AUTH_DB_DRIVER=sqlite                   # sqlite, postgres
AUTH_DB_PATH=/data/k8ops.db             # SQLite file path
AUTH_DB_DSN=                            # Postgres DSN (when driver=postgres)
                                        # postgres://user:pass@host:5432/k8ops?sslmode=disable

# Role provisioning
AUTH_DEFAULT_ROLE=viewer                # admin, operator, viewer, ns-admin, ns-viewer

# ============================================================================
# Dashboard
# ============================================================================
# Dashboard server
DASHBOARD_ADDRESS=:9090                 # HTTP listen address
DEBUG=false                             # Enable verbose logging (true/false)

# TLS (HTTPS) — mount cert/key via k8ops-dashboard-tls Secret
DASHBOARD_TLS_CERT=                     # /data/tls/tls.crt (empty for HTTP)
DASHBOARD_TLS_KEY=                      # /data/tls/tls.key (empty for HTTP)

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
# Comma-separated list of allowed origins for browser access.
# Required when dashboard is accessed from a different domain than the API.
CORS_ALLOWED_ORIGINS=                   # https://k8ops.example.com,http://localhost:9090

# ============================================================================
# Notifications
# ============================================================================
# Slack incoming webhook URL for alerts
# kubectl create secret generic k8ops-notifications \
#   --from-literal=slack-webhook-url="https://hooks.slack.com/..." -n k8ops-system
SLACK_WEBHOOK_URL=                      # k8ops-notifications/slack-webhook-url

# ============================================================================
# Controller / Manager
# ============================================================================
METRICS_BIND_ADDRESS=:8080              # Prometheus metrics server
HEALTH_PROBE_BIND_ADDRESS=:8081         # Health/readiness probe server
LEADER_ELECT=false                      # Enable for HA (not needed for DaemonSet)
DISABLE_EVENT_COLLECTOR=false           # Disable automatic event-triggered diagnostics

# ============================================================================
# Observability
# ============================================================================
K8OPS_AUDIT_LOG=                        # Audit log path (default: /tmp/k8ops-audit.log)

# ============================================================================
# Cost Estimation
# ============================================================================
K8OPS_CPU_PRICE=                        # Override CPU price per core/month (USD)
K8OPS_RAM_PRICE=                        # Override RAM price per GB/month (USD)

# ============================================================================
# Rate Limiting
# ============================================================================
PROVIDER_RATE_LIMIT_RPM=0               # AI API requests per minute (0 = unlimited)
